public class Ques1 {
    public static void main(String[] args) {

        String str = "Hello World";

        int count = 0;

        try {
            while (true) {
                str.charAt(count);
                count++;
            }
        } catch (Exception e) {
            // Exception occurs when index goes out of bounds
        }

        System.out.println("Length of the string: " + count);
    }
}
